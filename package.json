{
  "name": "zk-verifier-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@zk-verifier/web",
    "build:web": "npm run build --workspace=@zk-verifier/web",
    "build:circuits": "npm run build --workspace=@zk-verifier/circuits",
    "setup": "npm run setup --workspace=@zk-verifier/circuits",
    "anchor:build": "cd packages/contracts && anchor build",
    "anchor:deploy": "cd packages/contracts && anchor deploy"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "turbo": "latest"
  }
}